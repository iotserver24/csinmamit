rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Helper function to check if user is moderator
    function isModerator() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator';
    }
    
    // Helper function to check if user is admin or moderator
    function isAdminOrModerator() {
      return isAdmin() || isModerator();
    }
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is accessing their own data
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      // Users can read and write their own data
      allow read, write: if isOwner(userId);
      
      // Admins can read all user data
      allow read: if isAdmin();
      
      // Admins can create, update, and delete any user
      allow create, update, delete: if isAdmin();
      
      // Moderators can read user data but not modify
      allow read: if isModerator();
    }

    // Core Team Collection
    match /core/{docId} {
      // Public read access for core team members
      allow read: if true;
      
      // Only admins can create, update, or delete core team members
      allow create, update, delete: if isAdmin();
    }

    // Events Collection
    match /events/{docId} {
      // Public read access for published events
      allow read: if true;
      
      // Only admins can create, update, or delete events
      allow create, update, delete: if isAdmin();
      
      // Moderators can update event details but not create/delete
      allow update: if isModerator();
    }

    // Teams Collection
    match /teams/{docId} {
      // Authenticated users can read team data
      allow read: if isAuthenticated();
      
      // Authenticated users can create teams
      allow create: if isAuthenticated();
      
      // Team members can update their own team data
      allow update: if isAuthenticated() && 
                   (resource.data.leaderId == request.auth.uid || 
                    request.auth.uid in resource.data.user);
      
      // Admins can update any team
      allow update: if isAdmin();
      
      // Only admins can delete teams
      allow delete: if isAdmin();
    }

    // Recruits Collection
    match /recruits/{docId} {
      // Anyone can create recruit applications (public registration)
      allow create: if true;
      
      // Only admins can read recruit data
      allow read: if isAdmin();
      
      // Only admins can update recruit data
      allow update: if isAdmin();
      
      // Only admins can delete recruit data
      allow delete: if isAdmin();
    }

    // Subcollections for team members
    match /teams/{teamId}/members/{memberId} {
      // Team members can read member data
      allow read: if isAuthenticated();
      
      // Team leader can add/remove members
      allow write: if isAuthenticated() && 
                  get(/databases/$(database)/documents/teams/$(teamId)).data.leaderId == request.auth.uid;
      
      // Admins can manage all team members
      allow write: if isAdmin();
    }

    // Event registrations subcollection
    match /events/{eventId}/registrations/{registrationId} {
      // Authenticated users can read registrations
      allow read: if isAuthenticated();
      
      // Users can create their own registrations
      allow create: if isAuthenticated() && 
                   request.resource.data.userId == request.auth.uid;
      
      // Users can update their own registrations
      allow update: if isAuthenticated() && 
                   resource.data.userId == request.auth.uid;
      
      // Admins can manage all registrations
      allow write: if isAdmin();
    }

    // Notifications collection
    match /notifications/{docId} {
      // Users can read their own notifications
      allow read: if isAuthenticated() && 
                 resource.data.userId == request.auth.uid;
      
      // Admins can create notifications for any user
      allow create: if isAdmin();
      
      // Users can update their own notifications (mark as read)
      allow update: if isAuthenticated() && 
                   resource.data.userId == request.auth.uid;
      
      // Admins can delete any notification
      allow delete: if isAdmin();
    }

    // Analytics collection (for tracking)
    match /analytics/{docId} {
      // Only admins can read analytics
      allow read: if isAdmin();
      
      // System can write analytics (for tracking)
      allow write: if isAdmin();
    }

    // Settings collection (app configuration)
    match /settings/{docId} {
      // Public read access for app settings
      allow read: if true;
      
      // Only admins can modify settings
      allow write: if isAdmin();
    }

    // Audit logs collection
    match /audit_logs/{docId} {
      // Only admins can read audit logs
      allow read: if isAdmin();
      
      // System can write audit logs
      allow write: if isAdmin();
    }

    // Backup collection (for data backups)
    match /backups/{docId} {
      // Only admins can access backups
      allow read, write: if isAdmin();
    }
  }
} 